digraph "MLP" {
    rankdir=LR;
    node [shape=box, fontname="Helvetica", style=filled, fillcolor="#f5f5f5"];

    x [shape=ellipse, fillcolor="#cfe8ff", label="x\ntensor(784)"];
    fc1 [label="fc1\nLinear(in_features=784, out_features=256)"];
    relu1 [label="relu1\nReLU()"];
    drop1 [label="drop1\nDropout(p=0.3)"];
    fc2 [label="fc2\nLinear(in_features=256, out_features=128)"];
    relu2 [label="relu2\nReLU()"];
    fc3 [label="fc3\nLinear(in_features=128, out_features=10)"];
    out [label="out\nSoftmax(dim=1)", peripheries=2, fillcolor="#ffe9b3"];

    x -> fc1;
    fc1 -> relu1;
    relu1 -> drop1;
    drop1 -> fc2;
    fc2 -> relu2;
    relu2 -> fc3;
    fc3 -> out;
}
